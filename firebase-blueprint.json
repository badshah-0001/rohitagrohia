{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "User's photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "email"]
    },
    "Scan": {
      "title": "Scan",
      "description": "A security scan record.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user who performed the scan." },
        "score": { "type": "number", "description": "The security score (0-100)." },
        "report": { "type": "string", "description": "The AI-generated security report." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the scan was performed." },
        "signals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        }
      },
      "required": ["uid", "score", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/scans/{scanId}": {
      "schema": "Scan",
      "description": "Security scan history."
    }
  }
}
